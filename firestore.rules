rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        request.auth.token.email == "509sfsrideapp@gmail.com";
    }

    function isAvailableDriver() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.available == true;
    }

    function activeRideStatus(status) {
      return status in ["open", "accepted", "arrived", "picked_up"];
    }

    function riderCancelRideKeys() {
      return ["status", "canceledAt", "canceledBy"];
    }

    function driverAcceptRideKeys() {
      return [
        "status",
        "acceptedBy",
        "driverName",
        "driverPhone",
        "driverEmail",
        "driverPhotoUrl",
        "carYear",
        "carMake",
        "carModel",
        "carColor",
        "carPlate",
        "acceptedAt",
        "arrivedAt",
        "pickedUpAt",
        "completedAt",
        "canceledAt"
      ];
    }

    function driverRideUpdateKeys() {
      return [
        "status",
        "arrivedAt",
        "pickedUpAt",
        "completedAt",
        "destination",
        "driverLocation"
      ];
    }

    function ownerEditableUserFields() {
      return [
        "name",
        "firstName",
        "lastName",
        "username",
        "phone",
        "homeAddress",
        "homeStreet",
        "homeCity",
        "homeState",
        "homeZip",
        "rank",
        "rankOrRole",
        "flight",
        "riderPhotoUrl",
        "driverPhotoUrl",
        "carYear",
        "carMake",
        "carModel",
        "carColor",
        "carPlate",
        "locationServicesEnabled",
        "notificationsEnabled",
        "notificationTokens",
        "notificationTokenMap",
        "notificationDeviceId",
        "notificationsUpdatedAt",
        "available",
        "updatedAt",
        "emergencyRideAddressConsent",
        "emergencyRideDispatchMode"
      ];
    }

    match /users/{userId} {
      allow create: if isOwner(userId) &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.available == false;

      allow read: if isOwner(userId) || isAdmin();

      allow update: if isAdmin() || (
        isOwner(userId) &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownerEditableUserFields())
      );
    }

    match /usernames/{username} {
      allow read: if true;

      allow create: if signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.username == username &&
        request.resource.data.email == request.auth.token.email;

      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.username == username &&
        request.resource.data.email == request.auth.token.email
      );

      allow delete: if isAdmin() || (
        signedIn() &&
        resource.data.uid == request.auth.uid
      );
    }

    match /rides/{rideId} {
      allow create: if signedIn() &&
        request.resource.data.riderId == request.auth.uid &&
        request.resource.data.status == "open" &&
        request.resource.data.keys().hasOnly([
          "riderId",
          "riderName",
          "riderPhone",
          "riderEmail",
          "riderPhotoUrl",
          "riderRank",
          "riderLastName",
          "riderFlight",
          "pickup",
          "pickupLocationName",
          "pickupLocationAddress",
          "destination",
          "riderLocation",
          "dispatchMode",
          "dispatchFlight",
          "dispatchExpandedAt",
          "status",
          "isTestRide",
          "createdAt",
          "isEmergencyRide",
          "emergencySavedAddress"
        ]);

      allow read: if signedIn() && (
        (resource.data.status == "open" && isAvailableDriver()) ||
        resource.data.riderId == request.auth.uid ||
        resource.data.acceptedBy == request.auth.uid ||
        isAdmin()
      );

      allow update: if signedIn() && (
        isAdmin() ||
        (
          resource.data.riderId == request.auth.uid &&
          request.resource.data.riderId == resource.data.riderId &&
          resource.data.status in ["open", "accepted", "arrived"] &&
          request.resource.data.status == "canceled" &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(riderCancelRideKeys())
        ) ||
        (
          resource.data.status == "open" &&
          request.resource.data.status == "accepted" &&
          request.resource.data.acceptedBy == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(driverAcceptRideKeys())
        ) ||
        (
          resource.data.acceptedBy == request.auth.uid &&
          request.resource.data.acceptedBy == resource.data.acceptedBy &&
          (
            activeRideStatus(request.resource.data.status) ||
            request.resource.data.status == "completed"
          ) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(driverRideUpdateKeys())
        )
      );
    }

    match /rideLive/{rideId} {
      allow read: if signedIn() && (
        (get(/databases/$(database)/documents/rides/$(rideId)).data.status == "open" && isAvailableDriver()) ||
        get(/databases/$(database)/documents/rides/$(rideId)).data.riderId == request.auth.uid ||
        get(/databases/$(database)/documents/rides/$(rideId)).data.acceptedBy == request.auth.uid ||
        isAdmin()
      );

      allow create, update: if signedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/rides/$(rideId)).data.riderId == request.auth.uid ||
        get(/databases/$(database)/documents/rides/$(rideId)).data.acceptedBy == request.auth.uid
      );
    }

    match /globalMessages/{messageId} {
      allow read: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.senderUid == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 500 &&
        request.resource.data.senderRank is string &&
        request.resource.data.senderRank.size() > 0 &&
        request.resource.data.senderLastName is string &&
        request.resource.data.senderLastName.size() > 0 &&
        request.resource.data.senderFlight is string &&
        request.resource.data.senderFlight.size() > 0;
    }

    match /bugReports/{reportId} {
      allow create: if signedIn() &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.description is string &&
        request.resource.data.description.size() > 0 &&
        request.resource.data.description.size() <= 4000 &&
        request.resource.data.contactConsentByPhone is bool &&
        request.resource.data.reporterName is string &&
        request.resource.data.reporterName.size() > 0;

      allow read: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow create: if signedIn() &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.description is string &&
        request.resource.data.description.size() > 0 &&
        request.resource.data.description.size() <= 4000 &&
        request.resource.data.contactConsentByPhone is bool &&
        request.resource.data.reporterName is string &&
        request.resource.data.reporterName.size() > 0;

      allow read: if isAdmin();
    }

    match /auditLogs/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /inboxPosts/{postId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /userInboxPosts/{postId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow write: if false;
    }
  }
}
